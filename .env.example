# Runtime
APP_ENV=production
APP_NAME=CQuezadaSkin
BRAND_NAME=CQuezadaSkin

# Database (Railway MySQL or external MySQL)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Public URLs
FRONTEND_URL=https://cquezadaskin.cl
APP_URL=https://api.cquezadaskin.cl
ASSET_BASE_URL=https://api.cquezadaskin.cl
CORS_ALLOWED_ORIGINS=https://cquezadaskin.cl,https://www.cquezadaskin.cl

# Business contact
BUSINESS_EMAIL=
BUSINESS_PHONE=
BUSINESS_INSTAGRAM=

# SMTP mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="CQuezadaSkin"
MAIL_NOTIFY_TO=
MAIL_REPLY_TO=
MAIL_REPLY_TO_NAME="CQuezadaSkin"

